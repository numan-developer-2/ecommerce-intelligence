<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Commerce Intelligence Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes slideIn {
            from { transform: translateX(-100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .fade-in {
            animation: fadeIn 0.6s ease-out;
        }
        
        .slide-in {
            animation: slideIn 0.5s ease-out;
        }
        
        .pulse-loading {
            animation: pulse 1.5s ease-in-out infinite;
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold">E-Commerce Intelligence</h1>
                        <p class="text-gray-400 text-sm">Real-time Price & Demand Analytics</p>
                    </div>
                </div>
                
                <div class="flex items-center space-x-4">
                    <div id="apiStatus" class="flex items-center space-x-2 px-4 py-2 rounded-lg glass-effect">
                        <div class="w-3 h-3 bg-green-500 rounded-full pulse-loading"></div>
                        <span class="text-sm">API Connected</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Container -->
    <div class="container mx-auto px-4 py-8">
        
        <!-- Stats Cards -->
        <div id="statsContainer" class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <!-- Stats will be loaded here -->
        </div>

        <!-- Search and Filter -->
        <div class="glass-effect rounded-2xl p-6 mb-8 fade-in">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-2">Search Product</label>
                    <input type="text" id="searchInput" placeholder="Enter product ID or name..." 
                           class="w-full px-4 py-3 bg-gray-800 rounded-lg focus:ring-2 focus:ring-purple-500 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Forecast Days</label>
                    <select id="forecastDays" class="w-full px-4 py-3 bg-gray-800 rounded-lg focus:ring-2 focus:ring-purple-500 outline-none">
                        <option value="7">7 Days</option>
                        <option value="14" selected>14 Days</option>
                        <option value="30">30 Days</option>
                    </select>
                </div>
                <div class="flex items-end">
                    <button onclick="analyzeProduct()" 
                            class="w-full gradient-bg px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition transform hover:scale-105">
                        🔮 Analyze Product
                    </button>
                </div>
            </div>
        </div>

        <!-- Results Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Price Forecast Chart -->
            <div class="glass-effect rounded-2xl p-6 card-hover fade-in">
                <h3 class="text-xl font-bold mb-4 flex items-center">
                    <span class="bg-purple-600 p-2 rounded-lg mr-3">📈</span>
                    Price Forecast
                </h3>
                <canvas id="forecastChart"></canvas>
                <div id="forecastDetails" class="mt-4 space-y-2"></div>
            </div>

            <!-- Demand Prediction -->
            <div class="glass-effect rounded-2xl p-6 card-hover fade-in">
                <h3 class="text-xl font-bold mb-4 flex items-center">
                    <span class="bg-green-600 p-2 rounded-lg mr-3">🎯</span>
                    Demand Prediction
                </h3>
                <div id="demandResult" class="space-y-4">
                    <div class="text-center py-8 text-gray-400">
                        Enter product details to see demand prediction
                    </div>
                </div>
            </div>

            <!-- AI Insights -->
            <div class="glass-effect rounded-2xl p-6 card-hover fade-in lg:col-span-2">
                <h3 class="text-xl font-bold mb-4 flex items-center">
                    <span class="bg-blue-600 p-2 rounded-lg mr-3">🤖</span>
                    AI-Powered Insights
                </h3>
                <div id="aiInsights" class="bg-gray-800 rounded-lg p-6 min-h-[150px]">
                    <p class="text-gray-400 text-center">Select a product to get AI insights</p>
                </div>
                <button onclick="getAIInsight()" 
                        class="mt-4 w-full bg-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                    ✨ Generate AI Insight
                </button>
            </div>

        </div>

        <!-- Product List -->
        <div class="glass-effect rounded-2xl p-6 mt-8 fade-in">
            <h3 class="text-xl font-bold mb-4">Recent Products</h3>
            <div id="productList" class="overflow-x-auto">
                <table class="w-full">
                    <thead class="bg-gray-800">
                        <tr>
                            <th class="px-4 py-3 text-left">Product</th>
                            <th class="px-4 py-3 text-left">Price</th>
                            <th class="px-4 py-3 text-left">Rating</th>
                            <th class="px-4 py-3 text-left">Discount</th>
                            <th class="px-4 py-3 text-left">Action</th>
                        </tr>
                    </thead>
                    <tbody id="productTableBody" class="divide-y divide-gray-700">
                        <!-- Products will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
        <div class="glass-effect rounded-2xl p-8 text-center">
            <div class="animate-spin rounded-full h-16 w-16 border-t-4 border-purple-500 mx-auto mb-4"></div>
            <p class="text-xl">Loading...</p>
        </div>
    </div>

    <script>
        // Configuration
        const API_URL = 'http://localhost:8000'; // Change for production
        let forecastChart = null;
        let currentProductId = null;

        // Initialize dashboard
        async function initDashboard() {
            showLoading();
            try {
                await loadStats();
                await loadProducts();
            } catch (error) {
                console.error('Initialization error:', error);
                showError('Failed to load dashboard data');
            } finally {
                hideLoading();
            }
        }

        // Load statistics
        async function loadStats() {
            try {
                const response = await fetch(`${API_URL}/stats`);
                const data = await response.json();
                
                const statsHTML = `
                    <div class="glass-effect rounded-xl p-6 card-hover">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Total Products</p>
                                <p class="text-3xl font-bold mt-1">${data.total_products}</p>
                            </div>
                            <div class="bg-purple-600 p-4 rounded-full">
                                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                    
                    <div class="glass-effect rounded-xl p-6 card-hover">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Avg Price</p>
                                <p class="text-3xl font-bold mt-1">Rs. ${data.price_stats.average.toFixed(0)}</p>
                            </div>
                            <div class="bg-green-600 p-4 rounded-full">💰</div>
                        </div>
                    </div>
                    
                    <div class="glass-effect rounded-xl p-6 card-hover">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">Avg Rating</p>
                                <p class="text-3xl font-bold mt-1">${data.rating_stats.average.toFixed(1)} ⭐</p>
                            </div>
                            <div class="bg-yellow-600 p-4 rounded-full">⭐</div>
                        </div>
                    </div>
                    
                    <div class="glass-effect rounded-xl p-6 card-hover">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-gray-400 text-sm">On Sale</p>
                                <p class="text-3xl font-bold mt-1">${data.discount_stats.products_on_sale}</p>
                            </div>
                            <div class="bg-red-600 p-4 rounded-full">🏷️</div>
                        </div>
                    </div>
                `;
                
                document.getElementById('statsContainer').innerHTML = statsHTML;
            } catch (error) {
                console.error('Stats loading error:', error);
            }
        }

        // Load products
        async function loadProducts() {
            try {
                const response = await fetch(`${API_URL}/products?limit=10`);
                const data = await response.json();
                
                const tbody = document.getElementById('productTableBody');
                tbody.innerHTML = data.products.map(product => `
                    <tr class="hover:bg-gray-800 transition">
                        <td class="px-4 py-3">${product.title.substring(0, 50)}...</td>
                        <td class="px-4 py-3">Rs. ${product.price}</td>
                        <td class="px-4 py-3">${product.rating} ⭐</td>
                        <td class="px-4 py-3">${product.discount_pct}%</td>
                        <td class="px-4 py-3">
                            <button onclick="selectProduct('${product.product_id}')" 
                                    class="bg-purple-600 px-4 py-1 rounded-lg hover:bg-purple-700 transition">
                                Analyze
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Products loading error:', error);
            }
        }

        // Analyze product
        async function analyzeProduct() {
            const productId = document.getElementById('searchInput').value.trim();
            if (!productId) {
                alert('Please enter a product ID');
                return;
            }
            
            currentProductId = productId;
            showLoading();
            
            try {
                await Promise.all([
                    loadForecast(productId),
                    loadDemand(productId)
                ]);
            } catch (error) {
                console.error('Analysis error:', error);
                showError('Failed to analyze product');
            } finally {
                hideLoading();
            }
        }

        // Load forecast
        async function loadForecast(productId) {
            const days = document.getElementById('forecastDays').value;
            
            try {
                const response = await fetch(`${API_URL}/forecast`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ product_id: productId, days: parseInt(days) })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    displayForecast(data.forecast);
                }
            } catch (error) {
                console.error('Forecast error:', error);
            }
        }

        // Display forecast chart
        function displayForecast(forecast) {
            const ctx = document.getElementById('forecastChart');
            
            if (forecastChart) {
                forecastChart.destroy();
            }
            
            const labels = forecast.predictions.map(p => p.date);
            const prices = forecast.predictions.map(p => p.predicted_price);
            
            forecastChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Predicted Price',
                        data: prices,
                        borderColor: 'rgb(147, 51, 234)',
                        backgroundColor: 'rgba(147, 51, 234, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { labels: { color: 'white' } }
                    },
                    scales: {
                        x: { ticks: { color: 'white' }, grid: { color: 'rgba(255,255,255,0.1)' } },
                        y: { ticks: { color: 'white' }, grid: { color: 'rgba(255,255,255,0.1)' } }
                    }
                }
            });
            
            // Display details
            document.getElementById('forecastDetails').innerHTML = `
                <div class="flex justify-between p-3 bg-gray-800 rounded-lg">
                    <span>Trend:</span>
                    <span class="font-bold ${forecast.trend === 'increasing' ? 'text-green-400' : forecast.trend === 'decreasing' ? 'text-red-400' : 'text-yellow-400'}">
                        ${forecast.trend.toUpperCase()}
                    </span>
                </div>
                <div class="flex justify-between p-3 bg-gray-800 rounded-lg">
                    <span>Price Change:</span>
                    <span class="font-bold">${forecast.price_change_pct}%</span>
                </div>
            `;
        }

        // Load demand prediction
        async function loadDemand(productId) {
            try {
                const response = await fetch(`${API_URL}/products/${productId}`);
                const product = await response.json();
                
                const demandResponse = await fetch(`${API_URL}/demand`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        price: product.price,
                        original_price: product.original_price,
                        discount_pct: product.discount_pct,
                        rating: product.rating,
                        review_count: product.review_count || 0
                    })
                });
                
                const data = await demandResponse.json();
                
                if (data.success) {
                    displayDemand(data.prediction);
                }
            } catch (error) {
                console.error('Demand error:', error);
            }
        }

        // Display demand result
        function displayDemand(prediction) {
            const levelColor = {
                'Very High': 'bg-green-600',
                'High': 'bg-green-500',
                'Medium': 'bg-yellow-500',
                'Low': 'bg-orange-500',
                'Very Low': 'bg-red-500'
            };
            
            document.getElementById('demandResult').innerHTML = `
                <div class="text-center">
                    <div class="text-6xl font-bold mb-4">${prediction.demand_score}</div>
                    <div class="${levelColor[prediction.demand_level]} inline-block px-6 py-2 rounded-full text-xl font-bold">
                        ${prediction.demand_level}
                    </div>
                    <div class="mt-4 text-gray-400">
                        Confidence: ${(prediction.confidence * 100).toFixed(0)}%
                    </div>
                </div>
            `;
        }

        // Get AI insight
        async function getAIInsight() {
            if (!currentProductId) {
                alert('Please analyze a product first');
                return;
            }
            
            showLoading();
            
            try {
                const response = await fetch(`${API_URL}/ai-insight`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        product_id: currentProductId,
                        query: 'Analyze price trends and provide buying recommendations'
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    document.getElementById('aiInsights').innerHTML = `
                        <div class="prose prose-invert max-w-none">
                            <p class="text-gray-300 leading-relaxed">${data.insight}</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('AI insight error:', error);
                showError('Failed to generate AI insight');
            } finally {
                hideLoading();
            }
        }

        // Select product
        function selectProduct(productId) {
            document.getElementById('searchInput').value = productId;
            analyzeProduct();
        }

        // Utility functions
        function showLoading() {
            document.getElementById('loadingOverlay').classList.remove('hidden');
        }

        function hideLoading() {
            document.getElementById('loadingOverlay').classList.add('hidden');
        }

        function showError(message) {
            alert(message);
        }

        // Initialize on load
        window.addEventListener('load', initDashboard);
    </script>

</body>
</html>